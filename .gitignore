# ============== Unity Core ==============
# 缓存文件夹（绝对不能传）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
# 构建输出文件夹
/[Bb]uild/
/[Bb]uilds/
# 日志文件
/[Ll]ogs/
# 用户设置（个性化配置，不用传）
/[Uu]ser[Ss]ettings/
